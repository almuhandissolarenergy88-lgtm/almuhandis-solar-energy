</div>

<h1>معرض الصور والفيديوهات</h1>

<p>AL-MUHANDIS SOLAR ENERGY</p>

</header>

<input type="text" id="search" placeholder="ابحث باسم المشروع">

<section class="gallery">

<div class="gallery-item">

<img src="images/gallery/project1.jpg" alt="مشروع">

<h3>محطة 10 حصان</h3>

<p>الواحات - ألواح Jinko - إنفرتر INVT</p>

</div>

<div class="gallery-item">

<img src="images/gallery/project2.jpg" alt="مشروع">

<h3>محطة 20 حصان</h3>

<p>LONGi + FRECON</p>

</div>

<div class="gallery-item">

<img src="images/gallery/project3.jpg" alt="مشروع">

<h3>محطة 30 حصان</h3>

<p>Trina + Growatt</p>

</div>

<div class="gallery-item">

<img src="images/gallery/project4.jpg" alt="مشروع">

<h3>محطة 50 حصان</h3>

<p>JA Solar + Deye</p>

</div>

<div class="gallery-item">

<video controls>

<source src="videos/project1.mp4" type="video/mp4">

</video>

<h3>فيديو تنفيذ محطة</h3>

</div>

<div class="gallery-item">

<video controls>

<source src="videos/project2.mp4" type="video/mp4">

</video>

<h3>فيديو تشغيل محطة</h3>

</div>

</section>

<script>

const search=document.getElementById("search");

search.addEventListener("keyup",function(){

const value=this.value.toLowerCase();

document.querySelectorAll(".gallery-item").forEach(function(item){

item.style.display=item.innerText.toLowerCase().includes(value)?"block":"none";

});

});

</script>

</body>

</html> 
/* ==========================================
   معرض الصور والمشروعات والمحطات المستعملة
========================================== */

.projects,
.used-systems,
.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
gap:25px;
padding:30px;
}

.project,
.card,
.gallery-item{
background:#ffffff;
border-radius:18px;
overflow:hidden;
box-shadow:0 8px 25px rgba(0,0,0,.12);
transition:.35s;
}

.project:hover,
.card:hover,
.gallery-item:hover{
transform:translateY(-8px);
box-shadow:0 15px 35px rgba(0,0,0,.2);
}

.project img,
.card img,
.gallery img,
.gallery video{
width:100%;
height:250px;
object-fit:cover;
display:block;
}

.project h3,
.card h3,
.gallery h3{
padding:15px;
text-align:center;
color:#0b5d2a;
font-size:22px;
}

.project table,
.card table{
width:95%;
margin:15px auto;
border-collapse:collapse;
}

.project td,
.card td{
border:1px solid #ddd;
padding:10px;
text-align:center;
}

.project tr:nth-child(even),
.card tr:nth-child(even){
background:#f5f5f5;
}

.btn{
display:block;
width:220px;
margin:20px auto;
padding:12px;
text-align:center;
background:#0b8f45;
color:#fff;
text-decoration:none;
font-size:18px;
border-radius:10px;
transition:.3s;
}

.btn:hover{
background:#066d34;
}

.gallery-item p{
padding:0 15px 20px;
text-align:center;
color:#666;
}

video{
background:#000;
}

@media(max-width:768px){

.projects,
.used-systems,
.gallery{

grid-template-columns:1fr;

}

.project img,
.card img,
.gallery img,
.gallery video{

height:220px;

}

}

